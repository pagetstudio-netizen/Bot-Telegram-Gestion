# ─── Variables d'environnement requises ──────────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Port d'écoute du serveur (Plesk le définit automatiquement, sinon 8080)
PORT=8080

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=

# Base de données Supabase
SUPABASE_DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
SUPABASE_API_KEY=

# Clé secrète pour les sessions (chaîne aléatoire longue)
SESSION_SECRET=changez-moi-avec-une-chaine-aleatoire-longue

# ID Telegram du propriétaire du bot (pour le panel /owner)
BOT_OWNER_ID=
